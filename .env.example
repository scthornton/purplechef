# PurpleChef Configuration
# Copy to .env and fill in your values

# Caldera Server
CHEF_CALDERA_URL=http://localhost:8888
CHEF_CALDERA_API_KEY=your-caldera-api-key
CHEF_CALDERA_ALLOWED_GROUPS=["chef-targets"]

# LimaCharlie
CHEF_LC_OID=your-limacharlie-org-id
CHEF_LC_API_KEY=your-limacharlie-api-key

# LLM (OpenAI-compatible)
CHEF_LLM_BASE_URL=https://api.openai.com/v1
CHEF_LLM_API_KEY=your-openai-api-key
CHEF_LLM_MODEL=gpt-4o

# Safety
CHEF_DRY_RUN=true
CHEF_AUDIT_LOG=audit.jsonl
